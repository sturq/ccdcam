<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hud_bg"
    android:fitsSystemWindows="true">

    <!-- ============== PREVIEW (full-bleed under HUD) ============== -->
    <android.opengl.GLSurfaceView
        android:id="@+id/glView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/modeRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============== TOP HUD: REC dot + STBY/REC + timecode + tape mode + battery ============== -->
    <LinearLayout
        android:id="@+id/topHud"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="@id/glView"
        app:layout_constraintStart_toStartOf="@id/glView"
        app:layout_constraintEnd_toEndOf="@id/glView">

        <View
            android:id="@+id/recDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:background="@drawable/rec_dot"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/modeTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/hud_accent"
            android:letterSpacing="0.14"
            android:text="STBY"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/timecode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/hud_text"
            android:letterSpacing="0.08"
            android:text="00:00:00:00"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/aspectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textColor="@color/hud_accent"
            android:letterSpacing="0.1"
            android:background="?attr/selectableItemBackground"
            android:text="16:9"
            tools:ignore="HardcodedText" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="12dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/battery_indicator"
            android:contentDescription="@null" />
    </LinearLayout>

    <!-- viewfinder corner brackets -->
    <ImageView
        android:layout_width="22dp" android:layout_height="22dp"
        android:layout_margin="14dp"
        android:src="@drawable/bracket_tl"
        android:contentDescription="@null"
        app:layout_constraintTop_toBottomOf="@id/topHud"
        app:layout_constraintStart_toStartOf="@id/glView" />
    <ImageView
        android:layout_width="22dp" android:layout_height="22dp"
        android:layout_margin="14dp"
        android:src="@drawable/bracket_tr"
        android:contentDescription="@null"
        app:layout_constraintTop_toBottomOf="@id/topHud"
        app:layout_constraintEnd_toEndOf="@id/glView" />
    <ImageView
        android:layout_width="22dp" android:layout_height="22dp"
        android:layout_margin="14dp"
        android:src="@drawable/bracket_bl"
        android:contentDescription="@null"
        app:layout_constraintBottom_toTopOf="@id/bottomHud"
        app:layout_constraintStart_toStartOf="@id/glView" />
    <ImageView
        android:layout_width="22dp" android:layout_height="22dp"
        android:layout_margin="14dp"
        android:src="@drawable/bracket_br"
        android:contentDescription="@null"
        app:layout_constraintBottom_toTopOf="@id/bottomHud"
        app:layout_constraintEnd_toEndOf="@id/glView" />

    <!-- vertical zoom indicator pinned to right edge of preview -->
    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/topHud"
        app:layout_constraintBottom_toTopOf="@id/bottomHud"
        app:layout_constraintEnd_toEndOf="@id/glView">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/hud_dim"
            android:text="T"
            tools:ignore="HardcodedText" />
        <TextView
            android:id="@+id/zoomTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/hud_accent"
            android:letterSpacing="0.04"
            android:text="1.0×"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/hud_dim"
            android:text="W"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- bottom of preview HUD: date stamp -->
    <LinearLayout
        android:id="@+id/bottomHud"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="@id/glView"
        app:layout_constraintStart_toStartOf="@id/glView"
        app:layout_constraintEnd_toEndOf="@id/glView">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/hud_dim"
            android:letterSpacing="0.1"
            android:text="CCD CAM"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/dateTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/hud_text"
            android:letterSpacing="0.1"
            android:text="2026 01 01"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- ============== ANDROID-NATIVE CONTROLS BELOW PREVIEW ============== -->

    <!-- mode toggle -->
    <LinearLayout
        android:id="@+id/modeRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/controlRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/modePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="22dp"
            android:paddingVertical="6dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textColor="@color/hud_dim"
            android:background="?attr/selectableItemBackground"
            android:text="PHOTO"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/modeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="22dp"
            android:paddingVertical="6dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textColor="@color/hud_accent"
            android:background="?attr/selectableItemBackground"
            android:text="VIDEO"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/controlRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/shutterBtn"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center"
            android:background="@drawable/shutter_video"
            android:contentDescription="@string/shutter" />

        <ImageButton
            android:id="@+id/flipBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="36dp"
            android:background="@drawable/round_button_bg"
            android:src="@drawable/ic_flip"
            android:padding="12dp"
            android:contentDescription="@string/switch_camera" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
