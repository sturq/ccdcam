<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hud_bg"
    android:fitsSystemWindows="true">

    <!-- top status bar: REC dot + timecode + zoom -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/recDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:background="@drawable/rec_dot"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/timecode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/hud_text"
            android:letterSpacing="0.1"
            android:text="00:00"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/zoomTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/hud_accent"
            android:letterSpacing="0.05"
            android:text="1.0×"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- preview filling remaining vertical space -->
    <android.opengl.GLSurfaceView
        android:id="@+id/glView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/modeRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- mode toggle: PHOTO | VIDEO -->
    <LinearLayout
        android:id="@+id/modeRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/controlRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/modePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="22dp"
            android:paddingVertical="6dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textColor="@color/hud_dim"
            android:background="?attr/selectableItemBackground"
            android:text="PHOTO"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/modeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="22dp"
            android:paddingVertical="6dp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textColor="@color/hud_accent"
            android:background="?attr/selectableItemBackground"
            android:text="VIDEO"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- bottom control bar: gallery | shutter | flip -->
    <FrameLayout
        android:id="@+id/controlRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/shutterBtn"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center"
            android:background="@drawable/shutter_video"
            android:contentDescription="@string/shutter" />

        <ImageButton
            android:id="@+id/galleryBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="36dp"
            android:background="@drawable/round_button_bg"
            android:src="@drawable/ic_gallery"
            android:padding="12dp"
            android:contentDescription="@string/gallery" />

        <ImageButton
            android:id="@+id/flipBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="36dp"
            android:background="@drawable/round_button_bg"
            android:src="@drawable/ic_flip"
            android:padding="12dp"
            android:contentDescription="@string/switch_camera" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
